# Supabase (https://supabase.com/dashboard → your project → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key is used server-side only. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# Signs session cookies — REQUIRED for sign-in to work when Supabase is
# configured. Generate one with: openssl rand -hex 32
# Rotating it logs every member out at once.
SESSION_SECRET=

# When set, new accounts must supply this code (share it in the group chat).
# Leave empty to keep registration open.
CLUB_INVITE_CODE=
