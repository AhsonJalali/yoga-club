# Supabase (https://supabase.com/dashboard → your project → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key is used server-side only. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# Shared club passcode. Anyone in the group enters this once to log in.
# Pick something memorable. Example: "downward-dog-2026"
CLUB_CODE=
